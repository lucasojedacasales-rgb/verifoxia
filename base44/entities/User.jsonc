{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "description": "The role of the user in the app",
      "enum": [
        "admin",
        "user"
      ]
    },
    "display_name": {
      "type": "string",
      "description": "Nombre a mostrar en la app (editable por el usuario)"
    }
  },
  "required": [
    "role"
  ]
}